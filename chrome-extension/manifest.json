{
  "manifest_version": 3,
  "name": "FlexCoach Chat Handler",
  "version": "1.0",
  "description": "Adds click handlers to chats on FlexCoach dashboard",
  "permissions": ["tabs"],
  "host_permissions": ["http://localhost:3000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://fitstn.flexcoach.app/dashboard/chat*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
